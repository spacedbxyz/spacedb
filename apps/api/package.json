{
  "name": "@spacedb/api",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "format": "prettier --write \"{src,test}/**/*.ts\"",
    "format:check": "prettier --check \"{src,test}/**/*.ts\"",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm format:check && pnpm lint:check",
    "fix": "pnpm format && pnpm lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@nestjs-cls/transactional": "^3.2.0",
    "@nestjs-cls/transactional-adapter-drizzle-orm": "^1.2.3",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/terminus": "^11.1.1",
    "@orpc/nest": "^1.14.0",
    "@orpc/openapi": "^1.14.0",
    "@orpc/server": "^1.14.0",
    "@orpc/zod": "^1.14.0",
    "@scalar/nestjs-api-reference": "^1.1.11",
    "@spacedb/contract": "workspace:^",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.45.2",
    "js-yaml": "^4.1.1",
    "nestjs-cls": "^6.2.0",
    "postgres": "^3.4.9",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@swc/core": "^1.15.33",
    "@testcontainers/postgresql": "^11.10.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "25.6.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "testcontainers": "^11.10.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.5"
  }
}
